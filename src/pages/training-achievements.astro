---
import CathedralLayout from '../layouts/CathedralLayout.astro';
const basePath = import.meta.env.BASE_URL;
const assetBase = basePath.endsWith('/') ? basePath : `${basePath}/`;
---

<CathedralLayout title="3ヶ月研修成果物一覧">
	<article class="portfolio">
		<header class="section-intro">
			<div class="seal">
				<svg width="60" height="60" viewBox="0 0 100 100" fill="none" stroke="var(--divine-gold)">
					<circle cx="50" cy="50" r="45" stroke-width="2" />
					<rect x="35" y="35" width="30" height="30" stroke-width="1" transform="rotate(45 50 50)" />
				</svg>
			</div>
			<p class="preamble">3ヶ月研修成果発表</p>
			<h1>主な成果物一覧</h1>
			<p class="subtitle">PoC・Webアプリ・自動化・ガバナンスの4領域で作成した成果物</p>
		</header>

		<hr class="divider" />

		<section class="category-grid">
			<section class="category">
						<h2><span class="num">1.</span> 高度なAI機能・PoCアプリ</h2>
						<p class="lead">実務でのAI活用を見据え、お客様への提案（PoC）に直結するプロトタイプ群です。</p>
						<ul>
								<li>
									<div class="item-row">
										<a class="item-link" href="https://peeaaa-ant-plan2table.hf.space/area" target="_blank" rel="noopener noreferrer">PDF図面から面積・部屋情報抽出するアプリ（AI agent）</a>
										<a class="github-link" href="https://github.com/hayashi-antas/plan2table" target="_blank" rel="noopener noreferrer" aria-label="PDF図面抽出アプリのGitHub">
